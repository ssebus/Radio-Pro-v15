<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <title>Radio Pro v15 - Official Application Website</title>
    <meta name="description" content="Official website of Radio Pro v15. Listen to your favorite radio stations online for free and without ads on any device. RadioPro 15, Radio Pro V.">
    <meta name="keywords" content="Radio Pro v15, internet radio, radio pro, v15, Radio Pro 15, RadioPro15, RadioPro v15, Radio Pro V, radioprov, radio pro, radio v15, radio15, radjo pro, radio pro piętnaście, radiopro, radjo pro 15, radio pro v 15, radio pto, radjo pto, radio pro w15, radio pro15">
    
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📻</text></svg>">
    <link rel="apple-touch-icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 fill=%22%231a1a2e%22 rx=%2220%22/><text x=%225%22 y=%2280%22 font-size=%2280%22>📻</text></svg>">

    <style>
        :root { --bg: #0a0a14; --accent: #007aff; }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, system-ui, sans-serif; }
        body { background: var(--bg); min-height: 100vh; width: 100vw; display: flex; align-items: flex-start; justify-content: center; color: white; padding: 15px 5px; overflow-y: auto; }
        .window { width: 100%; height: auto; max-width: 500px; background: rgba(255, 255, 255, 0.04); backdrop-filter: blur(30px); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 20px; display: flex; flex-direction: column; box-shadow: 0 20px 50px rgba(0,0,0,0.5); transition: max-width 0.3s ease, height 0.3s ease; position: relative; margin-bottom: 30px; }
        
        .window.expanded-mode { max-width: 650px; margin-top: 10vh; }
        .window.expanded-mode .player { padding: 40px 20px; }
        .window.expanded-mode .icon-box { width: 140px; height: 140px; }
        .window.expanded-mode .icon-box img, .window.expanded-mode .icon-box .emoji-fallback { font-size: 70px; }
        .window.expanded-mode #curName { font-size: 1.8rem; margin-bottom: 15px; }
        .window.expanded-mode .sidebar { display: none !important; }

        .size-toggle-btn { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.1); color: white; width: 35px; height: 35px; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: background 0.2s; margin-top: 5px; }
        .size-toggle-btn:hover { background: rgba(255,255,255,0.2); }

        .player { flex: 0 0 auto; display: flex; flex-direction: column; align-items: center; padding: 15px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); position: relative; }
        #viz { width: 100%; height: 50px; }
        
        .icon-box { width: 90px; height: 90px; background: rgba(255,255,255,0.03); border-radius: 20px; display: flex; align-items: center; justify-content: center; margin: 10px 0; border: 1px solid rgba(255,255,255,0.1); transition: all 0.3s ease; overflow: hidden; }
        .icon-box img { width: 100%; height: 100%; object-fit: cover; }
        .icon-box .emoji-fallback { font-size: 45px; }

        .play-btn { width: 65px; height: 65px; background: white; color: black; border-radius: 50%; border: none; font-size: 22px; cursor: pointer; margin-bottom: 10px; }
        .sidebar { flex: 1; background: rgba(0,0,0,0.2); display: flex; flex-direction: column; padding: 15px; border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; }
        
        .search-area { background: rgba(255,255,255,0.08); border-radius: 10px; padding: 8px; display: flex; align-items: center; margin-bottom: 10px; border: 1px solid rgba(255, 255, 255, 0.1); gap: 5px; }
        .search-area input { background: none; border: none; color: white; flex: 1; outline: none; font-size: 14px; }
        
        .clear-search-btn { background: rgba(255,255,255,0.1); border: none; color: #ff3b30; font-weight: bold; width: 24px; height: 24px; border-radius: 6px; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 12px; transition: background 0.2s; }
        .clear-search-btn:hover { background: rgba(255,255,255,0.2); }

        .list-container { flex: 1; }
        .section-title { font-size: 10px; color: var(--accent); font-weight: 800; margin: 12px 0 6px 0; text-transform: uppercase; letter-spacing: 1px; }
        
        .item { padding: 10px; background: rgba(255,255,255,0.12); margin-bottom: 5px; border-radius: 10px; display: flex; align-items: center; gap: 10px; font-size: 14px; cursor: pointer; transition: background 0.2s ease, border-color 0.2s ease; border: 1px solid transparent; text-align: left; }
        .item.playing-now { background: rgba(0, 122, 255, 0.35) !important; border-color: var(--accent); font-weight: bold; }
        
        .item-icon { width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; border-radius: 6px; overflow: hidden; background: rgba(255,255,255,0.05); font-size: 14px; }
        .item-icon img { width: 100%; height: 100%; object-fit: cover; }

        .star { margin-left: auto; color: rgba(255,255,255,0.15); font-size: 24px; padding: 5px; }
        .star.active { color: #ffcc00; transform: scale(1.1); }
        
        .volume-container { display: flex; align-items: center; gap: 12px; margin-top: 8px; min-height: 32px; }
        .vol-btn { background: rgba(255, 255, 255, 0.08); border: 1px solid rgba(255, 255, 255, 0.1); color: white; font-size: 16px; font-weight: bold; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; user-select: none; transition: background 0.2s; }
        .vol-btn:hover { background: rgba(255, 255, 255, 0.2); }
        input[type="range"] { width: 130px; accent-color: var(--accent); cursor: pointer; }
        
        .ios-notice-container { display: flex; align-items: center; justify-content: center; gap: 10px; }
        .ios-notice { font-size: 12px; color: #ffffff; font-weight: 700; letter-spacing: 0.5px; background: rgba(255,255,255,0.1); padding: 6px 14px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.15); display: inline-block; z-index: 2; }
        .ios-disabled-slider { width: 80px; opacity: 0.25; cursor: not-allowed; pointer-events: none; accent-color: var(--accent); }

        .welcome-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.75); backdrop-filter: blur(10px); display: flex; align-items: center; justify-content: center; z-index: 1000; padding: 20px; }
        .welcome-box { background: #1a1a2e; border: 1px solid rgba(255,255,255,0.15); border-radius: 20px; max-width: 400px; width: 100%; padding: 25px; text-align: center; box-shadow: 0 20px 40px rgba(0,0,0,0.6); }
        .welcome-box h3 { font-size: 1.4rem; margin-bottom: 12px; color: var(--accent); display: flex; align-items: center; justify-content: center; gap: 8px; }
        .welcome-box p { font-size: 0.95rem; line-height: 1.5; color: rgba(255,255,255,0.85); margin-bottom: 20px; }
        .welcome-box ol { text-align: left; margin: 15px 0 20px 20px; color: rgba(255,255,255,0.9); font-size: 0.9rem; }
        .welcome-box ol li { margin-bottom: 8px; }
        .welcome-btn { background: white; color: black; border: none; padding: 10px 30px; font-weight: bold; border-radius: 25px; cursor: pointer; font-size: 1rem; transition: transform 0.2s; width: 100%; }
        .welcome-btn:hover { transform: scale(1.03); }
    </style>
</head>
<body>
    <h1 style="position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); border: 0;">Radio Pro v15</h1>

    <div class="welcome-overlay" id="welcomeScreen" style="display: none;">
        <div class="welcome-box">
            <h3>📻 Radio Pro v15</h3>
            <p>Welcome to the official application! Here is a quick guide on how to listen:</p>
            <ol>
                <li>Use the <b>Search</b> bar to find your favorite radio stations.</li>
                <li>Click on any station from the list to start playing.</li>
                <li>Tap the <b>★ star</b> icon to save stations to your Favorites.</li>
                <li>Use the <b>⤢ button</b> under the visualizer to expand the view!</li>
            </ol>
            <button class="welcome-btn" onclick="closeWelcome()">OK</button>
        </div>
    </div>

    <div class="window" id="appWindow">
        <div class="player">
            <canvas id="viz"></canvas>
            
            <button class="size-toggle-btn" onclick="toggleLayoutSize()" title="Toggle Compact View">⤢</button>

            <div class="icon-box" id="mainIconBox"><span class="emoji-fallback">📻</span></div>
            
            <h2 id="curName" style="font-size: 1.2rem; margin-bottom: 5px; text-align: center;">Ready to play</h2>
            <button class="play-btn" id="pBtn" onclick="togglePlay()">▶</button>
            
            <div class="volume-container" id="volControl">
                <button class="vol-btn" onclick="changeVolumeStep(-0.05)">−</button>
                <input type="range" id="volSlider" min="0" max="1" step="0.01" value="0.8">
                <button class="vol-btn" onclick="changeVolumeStep(0.05)">+</button>
            </div>
        </div>
        <div class="sidebar">
            <div class="search-area">
                <input type="text" id="sIn" placeholder="Search..." onkeypress="if(event.key==='Enter') search()" oninput="startInactivityTimer()">
                <button class="clear-search-btn" id="clearSearchBtn" onclick="clearSearchAndShowPopular()" title="Clear Search" style="display: none;">✕</button>
                <button onclick="search()" style="background:none; border:none; color:var(--accent); font-weight:bold; cursor:pointer; padding: 0 5px;">OK</button>
            </div>

            <div class="list-container">
                <div class="section-title">MY FAVORITES ★</div>
                <div id="favList"></div>
                <div id="popularSection">
                    <div class="section-title" id="mainListTitle">POPULAR STATIONS 📍</div>
                    <div id="resList"></div>
                </div>
            </div>
        </div>
    </div>

    <audio id="audio" playsinline preload="auto"></audio>

    <div style="position: absolute; left: -9999px; top: auto; width: 1px; height: 1px; overflow: hidden;" aria-hidden="true">
        <h2>Wyszukiwania powiązane z Radio Pro v15:</h2>
        <p>Oficjalna strona aplikacji Radio Pro v15. Szukasz Radio Pro 15, RadioPro15, lub RadioPro v15? Tutaj znajdziesz radio internetowe stabilne i szybkie.</p>
    </div>

    <script>
        const audio = document.getElementById('audio');
        const pBtn = document.getElementById('pBtn');
        const canvas = document.getElementById('viz');
        const ctx = canvas.getContext('2d');
        const volSlider = document.getElementById('volSlider');
        let favs = JSON.parse(localStorage.getItem('RADIO_STATIONS_FINAL')) || [];
        let currentStationUuid = null;
        let currentStationName = "Radio Pro v15";
        let currentStationFavicon = "";
        
        let regionalStationsBackup = []; 
        let inactivityTimer = null;

        let userDetectedRegion = "Rheinland-Pfalz";
        let userDetectedCountry = "Germany";

        audio.volume = volSlider.value;

        const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);

        if (isIOS) {
            document.getElementById('volControl').innerHTML = `
                <div class="ios-notice-container">
                    <span class="ios-notice">Use phone volume buttons 📱</span>
                    <input type="range" class="ios-disabled-slider" min="0" max="1" value="0.8" disabled>
                </div>
            `;
        }

        function checkWelcomeMessage() {
            const hasSeen = localStorage.getItem('hasSeenRadioWelcomeV15');
            if (!hasSeen) document.getElementById('welcomeScreen').style.display = 'flex';
        }

        document.getElementById('welcomeScreen').onclick = function(e) {
            if(e.target === this) closeWelcome();
        };

        function closeWelcome() {
            document.getElementById('welcomeScreen').style.display = 'none';
            localStorage.setItem('hasSeenRadioWelcomeV15', 'true');
        }

        function toggleLayoutSize() {
            const win = document.getElementById('appWindow');
            win.classList.toggle('expanded-mode');
            setTimeout(() => {
                canvas.width = canvas.offsetWidth;
                canvas.height = canvas.offsetHeight;
                drawStaticLine();
            }, 300);
        }

        function updateMediaSession(name, iconUrl) {
            if ('mediaSession' in navigator) {
                const artworkUrl = (iconUrl && iconUrl.trim() !== '') ? iconUrl : 'https://cdn-icons-png.flaticon.com/512/651/651717.png';
                navigator.mediaSession.metadata = new MediaMetadata({
                    title: name,
                    artist: "Radio Pro v15",
                    album: "Live Radio 📻",
                    artwork: [{ src: artworkUrl, sizes: '512x512', type: 'image/png' }]
                });
                navigator.mediaSession.playbackState = 'playing';
            }
        }

        if ('mediaSession' in navigator) {
            navigator.mediaSession.setActionHandler('play', () => { togglePlay(); });
            navigator.mediaSession.setActionHandler('pause', () => { togglePlay(); });
        }

        function drawStaticLine() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.beginPath(); 
            ctx.strokeStyle = '#007aff'; 
            ctx.lineWidth = 3;
            ctx.moveTo(0, canvas.height / 2);
            ctx.lineTo(canvas.width, canvas.height / 2);
            ctx.stroke();
        }

        function filterBestStations(stations) {
            const uniqueMap = new Map();
            stations.sort((a, b) => (b.clickcount || 0) - (a.clickcount || 0));

            for (const s of stations) {
                if (!s.url || s.url.trim() === '') continue;
                if ((s.clickcount || 0) <= 0) continue; 
                
                const cleanName = s.name.trim().toLowerCase();
                if (!uniqueMap.has(cleanName)) {
                    uniqueMap.set(cleanName, s);
                } else {
                    const existing = uniqueMap.get(cleanName);
                    if ((s.bitrate || 0) > (existing.bitrate || 0)) {
                        uniqueMap.set(cleanName, s);
                    }
                }
            }
            return Array.from(uniqueMap.values());
        }

        async function tryFetchIpLocation() {
            try {
                const response = await fetch('https://ip-api.com/json/?fields=status,country,regionName');
                const data = await response.json();
                if (data && data.status === 'success') {
                    if (data.regionName) setDetectedRegion(data.regionName);
                    if (data.country) userDetectedCountry = data.country;
                    return true;
                }
            } catch (e) {}

            try {
                const response = await fetch('https://ipapi.co/json/');
                const data = await response.json();
                if (data) {
                    if (data.region) setDetectedRegion(data.region);
                    if (data.country_name) userDetectedCountry = data.country_name;
                    return true;
                }
            } catch (e) {}
            return false;
        }

        function completelyRemovePopularSection() {
            localStorage.setItem('RADIO_POPULAR_SECTION_PERMANENTLY_REMOVED', 'true');
            const el = document.getElementById('popularSection');
            if (el) {
                el.remove();
            }
        }

        async function initLocalSystem() {
            if (localStorage.getItem('RADIO_POPULAR_SECTION_PERMANENTLY_REMOVED') === 'true') {
                completelyRemovePopularSection();
                return;
            }

            let ipSuccess = await tryFetchIpLocation();
            if (ipSuccess) {
                let success = await loadLocalStations(true);
                if (success) return; 
            }
            
            completelyRemovePopularSection();
        }

        function startBackgroundTracking() {
            setInterval(async () => {
                if (localStorage.getItem('RADIO_POPULAR_SECTION_PERMANENTLY_REMOVED') === 'true') return;
                let ipMoved = await tryFetchIpLocation();
                if (ipMoved) {
                    await loadLocalStations(false);
                }
            }, 300000); 
        }

        function setDetectedRegion(regionName) {
            let detected = regionName;
            if (detected === "North Rhine-Westphalia") detected = "Nordrhein-Westfalen";
            if (detected === "Lesser Poland" || detected === "Małopolska") detected = "Małopolskie";
            if (detected === "Mazovia") detected = "Mazowieckie";
            userDetectedRegion = detected;
        }

        async function loadLocalStations(isFromIpCheck = false) {
            const mainTitleEl = document.getElementById('mainListTitle');
            if (mainTitleEl) {
                mainTitleEl.innerText = `POPULAR STATIONS IN ${userDetectedRegion.toUpperCase()} 📍`;
            }

            let regionalStations = [];
            try {
                const res = await fetch(`https://de1.api.radio-browser.info/json/stations/bystate/${encodeURIComponent(userDetectedRegion)}?order=clickcount&reverse=true`);
                regionalStations = await res.json();
            } catch(e) { 
                console.log("API Fetch error"); 
                return false; 
            }

            regionalStationsBackup = filterBestStations(regionalStations);

            if (regionalStationsBackup.length === 0) {
                if (isFromIpCheck) {
                    completelyRemovePopularSection();
                    return false; 
                } else {
                    completelyRemovePopularSection();
                    return true;
                }
            } else {
                const resListEl = document.getElementById('resList');
                if (resListEl) {
                    renderList(regionalStationsBackup, resListEl);
                }
                return true; 
            }
        }

        function startInactivityTimer() {
            resetInactivityTimer();
            inactivityTimer = setTimeout(() => { clearSearchAndShowPopular(); }, 60000); 
        }

        function resetInactivityTimer() {
            if (inactivityTimer) { clearTimeout(inactivityTimer); inactivityTimer = null; }
        }

        async function search() {
            const q = document.getElementById('sIn').value;
            if (!q || q.trim() === '') return;
            
            document.getElementById('clearSearchBtn').style.display = 'flex'; 
            const mainTitleEl = document.getElementById('mainListTitle');
            if (mainTitleEl) {
                mainTitleEl.innerText = `SEARCH RESULTS`;
            }
            resetInactivityTimer();

            try {
                const res = await fetch(`https://de1.api.radio-browser.info/json/stations/byname/${encodeURIComponent(q)}`);
                const data = await res.json();
                const resListEl = document.getElementById('resList');
                if (resListEl) {
                    renderList(filterBestStations(data), resListEl);
                }
            } catch(e) {}
        }

        function clearSearchAndShowPopular() {
            resetInactivityTimer();
            document.getElementById('sIn').value = '';
            document.getElementById('clearSearchBtn').style.display = 'none';
            
            if (localStorage.getItem('RADIO_POPULAR_SECTION_PERMANENTLY_REMOVED') === 'true') {
                completelyRemovePopularSection();
                return;
            }

            const mainTitleEl = document.getElementById('mainListTitle');
            if (mainTitleEl) {
                mainTitleEl.innerText = `POPULAR STATIONS IN ${userDetectedRegion.toUpperCase()} 📍`;
            }
            
            if (regionalStationsBackup.length === 0) {
                initLocalSystem();
            } else {
                const resListEl = document.getElementById('resList');
                if (resListEl) {
                    renderList(regionalStationsBackup, resListEl);
                }
            }
        }

        function renderList(data, container) {
            container.innerHTML = '';
            if (data.length === 0) {
                container.innerHTML = `<div style="padding:10px; opacity:0.5; font-size:13px;">No stations found...</div>`;
                return;
            }
            data.forEach(s => {
                const isF = favs.some(f => f.stationuuid === s.stationuuid);
                const isPlaying = s.stationuuid === currentStationUuid;
                
                const div = document.createElement('div');
                div.className = `item ${isPlaying ? 'playing-now' : ''}`;
                div.setAttribute('data-uuid', s.stationuuid);
                
                const uniqueImgId = `img-list-${s.stationuuid}`;
                let iconHTML = `<div class="item-icon" id="box-list-${s.stationuuid}">📻</div>`;
                
                if(s.favicon && s.favicon.trim() !== '') {
                    iconHTML = `<div class="item-icon" id="box-list-${s.stationuuid}"><img src="${s.favicon}" id="${uniqueImgId}"></div>`;
                }
                
                div.innerHTML = `${iconHTML}<div style="flex:1; overflow:hidden"><b>${s.name}</b></div><div class="star ${isF?'active':''}" onclick="event.stopPropagation(); localToggleFav(this, ${JSON.stringify(s).replace(/"/g, '&quot;')})">★</div>`;
                
                if(s.favicon && s.favicon.trim() !== '') {
                    setTimeout(() => {
                        const imgEl = document.getElementById(uniqueImgId);
                        const boxEl = document.getElementById(`box-list-${s.stationuuid}`);
                        if(imgEl && boxEl) {
                            imgEl.onerror = () => { boxEl.innerHTML = '📻'; };
                            imgEl.onload = () => { if (imgEl.naturalWidth === 0 || imgEl.naturalHeight === 0) boxEl.innerHTML = '📻'; };
                        }
                    }, 10);
                }
                
                div.onclick = () => { play(s); };
                container.appendChild(div);
            });
        }

        function localToggleFav(starEl, s) {
            toggleFav(s);
            starEl.classList.toggle('active');
        }

        function toggleFav(s) {
            const idx = favs.findIndex(f => f.stationuuid === s.stationuuid);
            if (idx === -1) favs.push(s); else favs.splice(idx, 1);
            localStorage.setItem('RADIO_STATIONS_FINAL', JSON.stringify(favs));
            renderFavs();
        }

        function renderFavs() {
            const container = document.getElementById('favList');
            container.innerHTML = '';
            if (favs.length === 0) {
                container.innerHTML = `<div style="padding:10px; opacity:0.4; font-size:12px; text-align:center;">No favorite stations added yet ★</div>`;
                return;
            }
            favs.forEach(s => {
                const isPlaying = s.stationuuid === currentStationUuid;
                const div = document.createElement('div');
                div.className = `item ${isPlaying ? 'playing-now' : ''}`;
                div.setAttribute('data-uuid', s.stationuuid);
                
                const uniqueImgId = `img-fav-${s.stationuuid}`;
                let iconHTML = `<div class="item-icon" id="box-fav-${s.stationuuid}">📻</div>`;
                
                if(s.favicon && s.favicon.trim() !== '') {
                    iconHTML = `<div class="item-icon" id="box-fav-${s.stationuuid}"><img src="${s.favicon}" id="${uniqueImgId}"></div>`;
                }
                
                div.innerHTML = `${iconHTML}<div style="flex:1; overflow:hidden"><b>${s.name}</b></div><div class="star active" onclick="event.stopPropagation(); localToggleFav(this, ${JSON.stringify(s).replace(/"/g, '&quot;')})">★</div>`;
                
                if(s.favicon && s.favicon.trim() !== '') {
                    setTimeout(() => {
                        const imgEl = document.getElementById(uniqueImgId);
                        const boxEl = document.getElementById(`box-fav-${s.stationuuid}`);
                        if(imgEl && boxEl) {
                            imgEl.onerror = () => { boxEl.innerHTML = '📻'; };
                            imgEl.onload = () => { if (imgEl.naturalWidth === 0 || imgEl.naturalHeight === 0) boxEl.innerHTML = '📻'; };
                        }
                    }, 10);
                }
                
                div.onclick = () => { play(s); };
                container.appendChild(div);
            });
        }

        function play(s) {
            currentStationUuid = s.stationuuid;
            currentStationName = s.name;
            currentStationFavicon = s.favicon || "";
            
            document.getElementById('curName').innerText = s.name;
            
            const mainBox = document.getElementById('mainIconBox');
            if(s.favicon && s.favicon.trim() !== '') {
                mainBox.innerHTML = `<img src="${s.favicon}" id="mainIconImg">`;
                const mImg = document.getElementById('mainIconImg');
                mImg.onerror = () => { mainBox.innerHTML = '<span class="emoji-fallback">📻</span>'; };
                mImg.onload = () => { if(mImg.naturalWidth===0 || mImg.naturalHeight===0) mainBox.innerHTML = '<span class="emoji-fallback">📻</span>'; };
            } else {
                mainBox.innerHTML = '<span class="emoji-fallback">📻</span>';
            }

            audio.src = s.url;
            audio.play().then(() => {
                pBtn.innerText = "⏸";
                updateMediaSession(s.name, s.favicon);
                startVisualizer();
            }).catch(err => {
                console.log("Playback error:", err);
                pBtn.innerText = "▶";
            });

            renderFavs();
            if (localStorage.getItem('RADIO_POPULAR_SECTION_PERMANENTLY_REMOVED') !== 'true') {
                const resListEl = document.getElementById('resList');
                if (resListEl && regionalStationsBackup.length > 0) {
                    renderList(regionalStationsBackup, resListEl);
                }
            }
        }

        function togglePlay() {
            if (!audio.src || audio.src === window.location.href) return;
            if (audio.paused) {
                audio.play().then(() => {
                    pBtn.innerText = "⏸";
                    if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'playing';
                    startVisualizer();
                }).catch(() => {});
            } else {
                audio.pause();
                pBtn.innerText = "▶";
                if ('mediaSession' in navigator) navigator.mediaSession.playbackState = 'paused';
            }
        }

        function changeVolumeStep(amount) {
            if (isIOS) return;
            let v = volSlider.value * 1 + amount;
            if (v < 0) v = 0; if (v > 1) v = 1;
            volSlider.value = v;
            audio.volume = v;
        }

        if (!isIOS) {
            volSlider.oninput = function() {
                audio.volume = this.value;
            };
        }

        let vInterval = null;
        function startVisualizer() {
            if (vInterval) clearInterval(vInterval);
            vInterval = setInterval(() => {
                if (audio.paused) { clearInterval(vInterval); drawStaticLine(); return; }
                ctx.clearRect(0, 0, canvas.width, canvas.height);
                ctx.beginPath();
                ctx.strokeStyle = '#007aff';
                ctx.lineWidth = 3;
                ctx.moveTo(0, canvas.height / 2);
                for (let i = 0; i < canvas.width; i++) {
                    const amp = Math.sin(i * 0.05 + Date.now() * 0.01) * (10 + Math.random() * 8);
                    ctx.lineTo(i, canvas.height / 2 + amp);
                }
                ctx.stroke();
            }, 30);
        }

        window.onload = function() {
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
            drawStaticLine();
            checkWelcomeMessage();
            renderFavs();
            initLocalSystem();
            startBackgroundTracking();
        };

        window.onresize = function() {
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
            drawStaticLine();
        };
    </script>
</body>
</html>
